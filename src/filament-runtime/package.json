{
  "name": "filament-runtime",
  "version": "0.1.0",
  "description": "Filament POC Phase 1 runtime: signals + direct DOM ops + keyed LIS reconciliation. No render tree, no vdom, no .NET in the browser.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "main": "./dist/filament.js",
  "module": "./dist/filament.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/filament.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && tsc -p tsconfig.json",
    "size": "node scripts/size.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json",
    "verify": "npm run build && npm run typecheck && FILAMENT_REQUIRE_DIST=1 npm test && npm run size"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "happy-dom": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
