@* A REACTIVE class on a keyed list row, read off the LOOP VARIABLE (decision 152) -- the todo
   list's line-through. list() reuses a persisting key's row, so a class computed at create time
   would freeze (the #125 stale trap, applied to attributes): the fold must land in an effect
   INSIDE the row create function, reading the record's per-record signal. The Duel idiom:
   tasks is mutated, visible recomputed by reassignment. *@

<button id="add" @onclick="Add">add</button>

<ul id="list">@foreach (Item t in visible)
{
    <li @key="t.Id" class="flex gap-2 @(t.Done ? "line-through text-slate-400" : "text-slate-900")"><span>@t.Label</span><button class="toggle" @onclick="() => Toggle(t.Id)">toggle</button></li>
}</ul>

@code {
    record Item
    {
        public int Id { get; set; }
        public string Label { get; set; } = "";
        public bool Done { get; set; }
    }

    private List<Item> tasks = new List<Item>();
    private List<Item> visible = new List<Item>();
    private int nextId = 1;

    void Add()
    {
        Item t = new Item();
        t.Id = nextId;
        t.Label = "task";
        t.Done = false;
        nextId = nextId + 1;
        tasks.Add(t);
        Refresh();
    }

    void Toggle(int id)
    {
        for (int i = 0; i < tasks.Count; i++)
        {
            if (tasks[i].Id == id) { tasks[i].Done = !tasks[i].Done; }
        }
        Refresh();
    }

    void Refresh()
    {
        visible = tasks.Where(x => true).ToList();
    }
}
