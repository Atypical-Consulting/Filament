@using System.Text.Json
@inject IJSRuntime JS

@* THE TAILWIND TODO-LIST v2 (decision 161) -- the program's measured witness, now a REAL app.
   v1 (decision 154) proved the class surface; v2 adds everything the todo-v2 program widened:

   - PERSISTENCE: OnInitializedAsync (156) loads localStorage through the erased IJSRuntime
     bridge (133), JsonSerializer.Deserialize (157) re-wraps the mutated Done/Label props in
     per-record signals; every mutation Save()s the exact System.Text.Json wire shape back --
     the oracle asserts the STORED STRING byte-equal against Blazor's real serializer.
   - ENTER adds (159): the input's @onkeydown handler reads e.Key off the DOM event itself.
   - IN-PLACE EDIT (158): the row's @if mounts the edit input inside the reused row, and
     @bind works there because the effect lives in the row create (152's routing).
   - THE COUNT IS COMPUTED (160): Left derives from visible + each row's Done signal; the
     leftText-recompute boilerplate is GONE.

   State stays the Duel idiom -- tasks mutated (+ version), visible reassigned (153 refuses
   the mixed shape). Rendering rows sit on single lines (whitespace = text nodes).

   THE FILAMENT RESTYLE (BENCH n°67): dark stone panel, amber filament accent -- the design
   signature is the wire the rows themselves build: each li carries a border-l-2 segment, lit
   amber while pending, extinguished to stone when done. Mono type for what the machine says
   (title, buttons, count), sans for what the human types (labels, input). The toggle label is
   a REACTIVE ternary (done/undo) -- same Expr machinery as the class fold, in text position.
   The strike-through lives on the LABEL span (its own reactive ternary): text-decoration
   propagates from a flex row into its items, so a li-level line-through would strike the
   action buttons too -- the mirror caught it. *@

<TodoShell Title="todos"><div id="editor" class="mt-5 flex gap-2"><input id="new" aria-label="New todo" placeholder="what needs doing?" @bind="newText" @onkeydown="OnKey" class="w-1/2 grow rounded-lg border border-stone-700 bg-stone-950 px-3 py-2 text-amber-50 placeholder:text-stone-500 focus:outline-none focus:ring-2 focus:ring-amber-400/60" /><button id="add" @onclick="Add" class="rounded-lg bg-amber-400 px-4 py-2 font-mono text-sm font-semibold text-stone-950 hover:bg-amber-300 disabled:opacity-50">add</button></div>

<ul id="list" class="mt-6">@foreach (Item t in visible)
{
    <li @key="t.Id" class="flex items-center gap-2 border-l-2 py-1.5 pl-4 transition-colors hover:bg-stone-800/50 @(t.Done ? "border-stone-700 text-stone-500" : "border-amber-400 text-amber-50")"><span class="grow @(t.Done ? "line-through decoration-stone-600" : "no-underline")">@t.Label</span>@if (t.Id == editingId)
    {
        <input class="editbox w-40 rounded border border-stone-700 bg-stone-950 px-2 py-0.5 text-sm text-amber-50 focus:outline-none focus:ring-2 focus:ring-amber-400/60" @bind="editText" /><button class="save rounded px-2 py-0.5 font-mono text-xs text-amber-300 hover:bg-stone-800" @onclick="() => SaveEdit()">save</button>
    }<button class="edit rounded px-2 py-0.5 font-mono text-xs text-stone-500 hover:bg-stone-800 hover:text-amber-300" @onclick="() => StartEdit(t.Id)">edit</button><button class="toggle rounded px-2 py-0.5 font-mono text-xs text-stone-500 hover:bg-stone-800 hover:text-amber-300" @onclick="() => Toggle(t.Id)">@(t.Done ? "undo" : "done")</button><button class="remove rounded px-2 py-0.5 font-mono text-xs text-stone-500 hover:bg-stone-800 hover:text-red-400" @onclick="() => Remove(t.Id)">remove</button></li>
}</ul>

<TodoFooter Left="@Left" OnClear="@ClearDone" /></TodoShell>

@code {
    // Mutable record, Rows' Row shape: Toggle and SaveEdit rewrite props in place.
    record Item
    {
        public int Id { get; set; }
        public string Label { get; set; } = "";
        public bool Done { get; set; }
    }

    private string newText = "";
    private List<Item> tasks = new List<Item>();
    private List<Item> visible = new List<Item>();
    private int editingId = 0;
    private string editText = "";
    private int nextId = 1;

    // Derived state (decision 160): re-runs when visible is reassigned AND when any row's
    // Done signal flips -- the whole point of computed over the manual recompute.
    private string Left => visible.Where(x => !x.Done).Count() + " left";

    protected override async Task OnInitializedAsync()
    {
        var raw = await JS.InvokeAsync<string>("localStorage.getItem", "todos");
        if (raw != null)
        {
            var data = JsonSerializer.Deserialize<List<Item>>(raw);
            if (data != null)
            {
                for (int i = 0; i < data.Count; i++)
                {
                    tasks.Add(data[i]);
                    if (data[i].Id >= nextId) { nextId = data[i].Id + 1; }
                }
                Refresh();
            }
        }
    }

    void OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { Add(); }
    }

    async Task Add()
    {
        if (newText == "") { return; }
        Item t = new Item();
        t.Id = nextId;
        t.Label = newText;
        t.Done = false;
        nextId = nextId + 1;
        tasks.Add(t);
        newText = "";
        Refresh();
        await Save();
    }

    async Task Toggle(int id)
    {
        for (int i = 0; i < tasks.Count; i++)
        {
            if (tasks[i].Id == id) { tasks[i].Done = !tasks[i].Done; }
        }
        Refresh();
        await Save();
    }

    async Task Remove(int id)
    {
        for (int i = tasks.Count - 1; i >= 0; i--)
        {
            if (tasks[i].Id == id) { tasks.RemoveAt(i); }
        }
        Refresh();
        await Save();
    }

    // void, not async Task: an EventCallback aliases an Action-shaped method (decision 130),
    // so the child-raised handler fires Save() without awaiting it -- the OnKey->Add pattern.
    void ClearDone()
    {
        for (int i = tasks.Count - 1; i >= 0; i--)
        {
            if (tasks[i].Done) { tasks.RemoveAt(i); }
        }
        Refresh();
        Save();
    }

    void StartEdit(int id)
    {
        editingId = id;
        for (int i = 0; i < tasks.Count; i++)
        {
            if (tasks[i].Id == id) { editText = tasks[i].Label; }
        }
    }

    async Task SaveEdit()
    {
        for (int i = 0; i < tasks.Count; i++)
        {
            if (tasks[i].Id == editingId) { tasks[i].Label = editText; }
        }
        editingId = 0;
        Refresh();
        await Save();
    }

    async Task Save()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", "todos", JsonSerializer.Serialize(tasks));
    }

    void Refresh()
    {
        visible = tasks.Where(x => true).ToList();
    }
}
