@* Leaf-display child with the OTHER two composition directions: a reactive bound string coming
   DOWN (decision 90 -- Left follows the parent's leftText) and an EventCallback going UP
   (decision 130 -- #clear runs the parent's ClearDone). *@
<footer id="footer" class="mt-6 flex items-center justify-between border-t border-stone-800 pt-3"><span id="left" class="font-mono text-xs text-stone-400">@Left</span><button id="clear" class="font-mono text-xs text-stone-500 hover:text-amber-300 hover:underline" @onclick="OnClear">clear done</button></footer>

@code {
    [Parameter] public string Left { get; set; } = "";
    [Parameter] public EventCallback OnClear { get; set; }
}
