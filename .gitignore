bin/
obj/
node_modules/
dist/
.DS_Store
*.user
test-results/
playwright-report/

# Publish output: regenerable from source via bench/publish-baseline.sh.
# Multi-megabyte wasm; never committed.
bench/publish/

# Demo dev bundles: regenerable via demo/build.sh, never committed (same rule as bench/publish/).
demo/dist/

# bench/results/ is DELIBERATELY NOT ignored. Those JSON files are the measured
# evidence behind BENCH.md -- the whole point of the baseline. Ignoring them was
# the reproducibility gap flagged as BENCH.md open reserve #4.
#
# No pattern here on purpose: `bench/results/*` followed by `!bench/results/*.json`
# does NOT work, because git cannot re-include a file whose parent directory is
# excluded -- it silently dropped every file under bench/results/final-warm/.

# Generator output. bench/build-filament.sh deletes and re-emits these from
# samples/Counter/Counter.razor and baseline/Rows.Blazor/RowsApp.razor on every
# build of the -gen labels, so they are regenerable by definition. NOT committed,
# and the reason is not tidiness: a generated file that lives in the tree is one
# somebody eventually hand-edits, and C1 would then be measured on a bundle the
# generator did not emit while the label still claimed it did.
# tests/Filament.Generator.Tests moves its own generator output out of the repo
# for the same reason.
samples/filament-counter-gen/Counter.g.js
samples/filament-rows-gen/Rows.g.js
samples/filament-if-gen/If.g.js
samples/filament-divide-gen/Divide.g.js
samples/filament-divideint-gen/DivideInt.g.js
samples/filament-compose-gen/App.g.js
samples/filament-rootforeach-gen/App.g.js
samples/filament-rootif-gen/App.g.js
samples/filament-boundcompose-gen/App.g.js
samples/filament-reactiveattr-gen/App.g.js
samples/filament-boolattr-gen/App.g.js
samples/filament-mixedattr-gen/App.g.js
samples/filament-stringattrs-gen/App.g.js
samples/filament-ifmulti-gen/App.g.js
samples/filament-ifelsemulti-gen/App.g.js
samples/filament-ifnested-gen/App.g.js

# examples/FilamentApp: emitted/copied at build, never committed (same rule as samples/*.g.js).
examples/FilamentApp/wwwroot/App.g.js
examples/FilamentApp/wwwroot/filament.js

# Approval-test output. `*.received.js` is what the generator ACTUALLY emitted when a
# snapshot went red -- a debugging artifact written by the failing test itself, next to
# the approved file it disagrees with. Committing one would put a REJECTED module in the
# tree beside the accepted one, named almost identically. Section 10 makes the snapshot
# the only wall against silent generator regressions; the wall is the .approved.js, and
# it is committed.
tests/Filament.Generator.Tests/Snapshots/*.received.js

# Editor/tooling scratch, never committed.
.idea/
.claude/
.superpowers/

# Local NuGet feed (Filament.Sdk nupkgs): build artifacts, regenerable via `dotnet pack src/Filament.Sdk`.
artifacts/
