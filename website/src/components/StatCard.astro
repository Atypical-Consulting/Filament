---
interface Props {
  value: string;
  unit?: string;
  label: string;
  sub?: string;
  accent?: "filament" | "spark";
}
const { value, unit, label, sub, accent = "filament" } = Astro.props;
const ring =
  accent === "spark"
    ? "hover:border-spark-400/60 hover:shadow-[0_0_40px_-12px] hover:shadow-spark-400/40"
    : "hover:border-filament-500/60 hover:shadow-[0_0_40px_-12px] hover:shadow-filament-500/40";
const val = accent === "spark" ? "text-spark-300" : "text-filament-400";
---

<div
  class:list={[
    "group rounded-2xl border border-ink-700 bg-ink-850/60 p-6 transition-all duration-300",
    ring,
  ]}
>
  <div class="flex items-baseline gap-1.5 font-mono">
    <span class:list={["text-4xl font-semibold tracking-tight md:text-5xl", val]}>{value}</span>
    {unit && <span class="text-lg font-medium text-mist-500">{unit}</span>}
  </div>
  <p class="mt-3 text-sm font-semibold text-mist-100">{label}</p>
  {sub && <p class="mt-1 text-sm leading-relaxed text-mist-500">{sub}</p>}
</div>
