---
import { Code } from "astro:components";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import StatCard from "../components/StatCard.astro";

const razorInput = `<h1 id="title">Counter</h1>

<p>Current count: <span id="counter-value">@currentCount</span></p>

<button id="increment" @onclick="Increment">Click me</button>

@code {
    private int currentCount = 0;

    private void Increment()
    {
        currentCount++;
    }
}`;

const jsOutput = `export function mount(target) {
  const currentCount = signal(0);

  const p = document.createElement('p');
  insert(p, document.createTextNode('Current count: '));
  const span = document.createElement('span');
  span.id = 'counter-value';
  const t = document.createTextNode('');
  insert(span, t); insert(p, span);

  const button = document.createElement('button');
  button.id = 'increment';
  insert(button, document.createTextNode('Click me'));

  // one binding point -> one effect
  effect(() => setText(t, currentCount.value));
  listen(button, 'click', () => { currentCount.value++; });

  insert(target, p);
  insert(target, button);
}`;

const subset = [
  {
    title: "Control flow",
    items: "@if / @else / @else if, @foreach, nested & multi-node bodies, root-level conditionals",
  },
  {
    title: "C# statements",
    items: "for, while, do-while, switch, try/catch, throw, lock, local declarations, compound assignment",
  },
  {
    title: "Numeric types",
    items: "int, long → BigInt, float → Math.fround, decimal (boxed), DateTime → tick math",
  },
  {
    title: "Collections",
    items: "List<T>, T[], Dictionary<K,V> — read, reassign, and element write (copy-on-write signals)",
  },
  {
    title: "LINQ",
    items: "Where / Select / OrderBy / GroupBy / Sum / First / Skip / Take — the whole common surface",
  },
  {
    title: "Reactivity & events",
    items: "@bind two-way, lambda handlers, reactive attributes, async/await → Promise",
  },
  {
    title: "The framework layer",
    items:
      "@page routing, @inject, @inherits, RenderFragment / ChildContent, EventCallback, @ref, CascadingParameter, generics, JS interop, EditForm — all eleven closed and measured",
  },
  {
    title: "Real-world I/O",
    items:
      "HttpClient → fetch, JSON under a shape gate, the wall clock, seeded Random proven against the BCL, OnInitialized(Async), computed properties",
  },
];

// THE HONEST LIST, and it is the current one. Nine framework features used to sit here; ADR 0003
// closed and measured all eleven, and this page went on claiming they were missing. What belongs
// here is what is refused TODAY -- including the two the post-ADR-0003 probe re-opened as real gaps.
const nonGoals = [
  "SSR / prerendering",
  "CSS isolation (.razor.css)",
  "Error boundaries",
  "Form validation — refused, not ignored",
  "A general DI container",
  "OnAfterRender / OnParametersSet / IDisposable",
  "Templated components (RenderFragment<T>)",
  'Route parameters — :guid, catch-all {*Rest}, and optional {id?}',
];
---

<Layout>
  <span id="top"></span>
  <Nav />

  <main id="main">
    <!-- ───────────────────────── HERO ───────────────────────── -->
    <section class="relative overflow-hidden">
      <div
        class="pointer-events-none absolute inset-0 -z-10"
        aria-hidden="true"
        style="background:
          radial-gradient(60rem 32rem at 70% -10%, rgba(255,176,32,0.12), transparent 60%),
          radial-gradient(50rem 30rem at 10% 10%, rgba(52,216,200,0.08), transparent 55%);"
      >
      </div>

      <div class="mx-auto max-w-6xl px-6 pb-20 pt-20 md:pt-28">
        <p
          class="inline-flex items-center gap-2 rounded-full border border-ink-700 bg-ink-850/70 px-3.5 py-1.5 text-xs font-medium text-mist-300"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-spark-400"></span>
          A research compiler · every number measured against Blazor
        </p>

        <h1
          class="mt-6 max-w-4xl text-balance text-5xl font-extrabold leading-[1.05] tracking-tight md:text-7xl"
        >
          Blazor components.<br />
          <span class="glow-text text-filament-400">Compiled to JavaScript.</span>
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-mist-300 md:text-xl">
          Filament turns Blazor-style <code class="rounded bg-ink-800 px-1.5 py-0.5 text-mist-100"
            >.razor</code
          > components — template <em>and</em> C# <code
            class="rounded bg-ink-800 px-1.5 py-0.5 text-mist-100">@code</code
          > — into lean static HTML + JS and a tiny signals runtime. No .NET in the browser.
          No megabyte download. No virtual DOM.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a
            href="#solution"
            class="rounded-xl bg-filament-500 px-5 py-3 text-sm font-semibold text-ink-950 transition-transform hover:scale-[1.02] hover:bg-filament-400"
            >See how it works</a
          >
          <a
            href="#evidence"
            class="rounded-xl border border-ink-600 px-5 py-3 text-sm font-semibold text-mist-100 transition-colors hover:border-spark-400/60 hover:text-spark-300"
            >Read the measurements</a
          >
        </div>

        <div class="mt-16 filament-rule max-w-3xl"></div>

        <dl class="mt-10 grid grid-cols-2 gap-x-8 gap-y-6 md:grid-cols-4">
          <div>
            <dt class="text-sm text-mist-500">Counter bundle (gzip)</dt>
            <dd class="mt-1 font-mono text-3xl font-semibold text-filament-400">
              2,987<span class="ml-1 text-base text-mist-500">B</span>
            </dd>
          </div>
          <div>
            <dt class="text-sm text-mist-500">Signals runtime</dt>
            <dd class="mt-1 font-mono text-3xl font-semibold text-filament-400">
              &lt;2<span class="ml-1 text-base text-mist-500">KB</span>
            </dd>
          </div>
          <div>
            <dt class="text-sm text-mist-500">.NET in browser</dt>
            <dd class="mt-1 font-mono text-3xl font-semibold text-spark-300">0<span
                class="ml-1 text-base text-mist-500">bytes</span
              ></dd>
          </div>
          <div>
            <dt class="text-sm text-mist-500">Update cost</dt>
            <dd class="mt-1 font-mono text-3xl font-semibold text-spark-300">
              1<span class="ml-1 text-base text-mist-500">DOM write</span>
            </dd>
          </div>
        </dl>
      </div>
    </section>

    <!-- ───────────────────────── PROBLEM ───────────────────────── -->
    <section id="problem" class="border-t border-ink-800 bg-ink-900/40">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <p class="text-sm font-semibold uppercase tracking-widest text-filament-500">The problem</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-bold tracking-tight md:text-4xl">
          Blazor WebAssembly ships a runtime the size of an application.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-mist-300">
          The component model is excellent. The delivery isn't. To render a counter, a Blazor
          WASM app downloads and boots the .NET runtime in the browser before a single pixel
          appears — an interpreter or AOT payload to warm, and a render tree that diffs on every
          change.
        </p>

        <div
          class="mt-8 flex flex-col gap-4 rounded-2xl border border-ink-700 bg-ink-850/50 p-6 sm:flex-row sm:items-center sm:justify-between"
        >
          <div>
            <p class="text-sm text-mist-500">A 1,000-row grid, gzipped, over the wire</p>
            <div class="mt-3 flex flex-wrap items-baseline gap-x-6 gap-y-2 font-mono">
              <span class="text-mist-400">
                Blazor WASM <span class="text-2xl font-semibold text-mist-200">1.88 MB</span>
              </span>
              <span class="text-mist-400">
                Filament <span class="text-2xl font-semibold text-filament-400">4.4 KB</span>
              </span>
            </div>
          </div>
          <div class="shrink-0 text-right">
            <span class="font-mono text-4xl font-bold text-spark-300">~432×</span>
            <p class="text-sm text-mist-500">lighter</p>
          </div>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-3">
          {
            [
              {
                h: "Weight",
                p: "The framework is the payload. Your code is a rounding error next to the runtime it rides in on.",
              },
              {
                h: "Startup",
                p: "Nothing renders until .NET is fetched, instantiated, and warm. First paint waits on a VM.",
              },
              {
                h: "DOM churn",
                p: "A render tree re-diffs to find what changed. The machinery to compute one text update isn't free.",
              },
            ].map((c) => (
              <div class="rounded-2xl border border-ink-800 bg-ink-850/50 p-6">
                <h3 class="text-lg font-semibold text-mist-100">{c.h}</h3>
                <p class="mt-2 text-sm leading-relaxed text-mist-500">{c.p}</p>
              </div>
            ))
          }
        </div>

        <p class="mt-10 max-w-2xl text-lg leading-relaxed text-mist-300">
          The question Filament asks: <span class="font-semibold text-mist-100"
            >what if the component model stayed, and the runtime left?</span
          >
        </p>
      </div>
    </section>

    <!-- ───────────────────────── SOLUTION ───────────────────────── -->
    <section id="solution">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <p class="text-sm font-semibold uppercase tracking-widest text-spark-400">How it works</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-bold tracking-tight md:text-4xl">
          Compile the component at build time. Ship the result, not the framework.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-mist-300">
          Filament reads the same <code class="text-mist-100">.razor</code> file Blazor compiles
          and lowers it — with Roslyn — to plain, imperative JavaScript. Static structure becomes
          create-once DOM calls. State becomes a <span class="text-filament-400">signal</span>. Each
          binding becomes one <span class="text-filament-400">effect</span>. There is no template to
          parse at runtime and no virtual DOM to diff.
        </p>

        <div class="mt-12 grid gap-6 lg:grid-cols-2">
          <div class="rounded-2xl border border-ink-700 bg-ink-900/70 p-1">
            <div class="flex items-center gap-2 px-4 py-2.5 text-xs font-medium text-mist-500">
              <span class="h-2.5 w-2.5 rounded-full bg-filament-500"></span>
              Counter.razor · what you write
            </div>
            <Code
              code={razorInput}
              lang="razor"
              theme="github-dark"
              class="!bg-transparent overflow-x-auto rounded-xl p-4 text-sm"
            />
          </div>
          <div class="rounded-2xl border border-ink-700 bg-ink-900/70 p-1">
            <div class="flex items-center gap-2 px-4 py-2.5 text-xs font-medium text-mist-500">
              <span class="h-2.5 w-2.5 rounded-full bg-spark-400"></span>
              mount() · what ships (abridged)
            </div>
            <Code
              code={jsOutput}
              lang="javascript"
              theme="github-dark"
              class="!bg-transparent overflow-x-auto rounded-xl p-4 text-sm"
            />
          </div>
        </div>

        <div class="mt-12 grid gap-5 md:grid-cols-4">
          {
            [
              { n: "1", h: "create", p: "The element tree is built once, imperatively. Static markup is static code." },
              { n: "2", h: "signal", p: "private int currentCount lifts to signal(0) at compile time — you never wrote it." },
              { n: "3", h: "effect", p: "One effect per binding. @currentCount → one node updated, nothing diffed." },
              { n: "4", h: "listen", p: "@onclick maps to a single event listener. The handler body is translated, not spliced." },
            ].map((s) => (
              <div class="rounded-2xl border border-ink-800 bg-ink-850/50 p-5">
                <span class="font-mono text-sm text-filament-500">0{s.n}</span>
                <h3 class="mt-2 font-mono text-lg font-semibold text-mist-100">{s.h}</h3>
                <p class="mt-2 text-sm leading-relaxed text-mist-500">{s.p}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ───────────────────────── EVIDENCE ───────────────────────── -->
    <section id="evidence" class="border-t border-ink-800 bg-ink-900/40">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <p class="text-sm font-semibold uppercase tracking-widest text-filament-500">The evidence</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-bold tracking-tight md:text-4xl">
          Four criteria. Measured, not asserted.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-mist-300">
          Two demo apps — <code class="text-mist-100">Counter</code> and a 1,000-row
          <code class="text-mist-100">Rows</code> — compiled from pure <code class="text-mist-100"
            >.razor</code
          > and benchmarked against the same apps built with Blazor WASM (interpreted and AOT).
          For the app-level head-to-head — a routed task board with a form, a keyed list and
          per-row handlers, measured on weight, time-to-interactive and memory — see
          <a
            class="font-semibold text-filament-400 underline decoration-filament-500/40 underline-offset-4 hover:decoration-filament-400"
            href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/benchmark`}>the Duel</a
          >.
        </p>

        <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
          <StatCard
            value="2,987"
            unit="B"
            label="C1 · Bundle weight"
            sub="Counter gzip. Rows 4,373 B. The signals runtime fits in a 2 KB budget."
          />
          <StatCard
            value="1"
            unit="write"
            label="C3 · DOM writes"
            sub="Rows #update: 100 characterData writes, zero reconcile. #swap: exactly 2 node moves."
            accent="spark"
          />
          <StatCard
            value="3.10"
            unit="ms"
            label="C4 · Create-warm"
            sub="Rows-gen vs 7.90 ms for the faster Blazor/AOT — and it wins on update, swap, and clear too."
          />
          <StatCard
            value="≥11×"
            unit=""
            label="C4 · Increment"
            sub="A conservative floor — the real figure is below the performance.now() quantum, so it isn't quoted higher."
            accent="spark"
          />
        </div>

        <div
          class="mt-8 rounded-2xl border border-ink-700 bg-ink-850/40 p-6 text-sm leading-relaxed text-mist-400"
        >
          <span class="font-semibold text-mist-100">The honest ceiling.</span> C1 (weight) and C4
          (speed) pass for both apps, including the full 1,000-row DOM work. These are
          <em>provisional research measurements</em> — coarse ratios are not cited to three
          significant figures, and every figure carries a disclosed reserve in
          <code class="text-mist-300">BENCH.md</code>. Demo apps — plus a persisted todo app and a
          head-to-head task board — show the architecture is <em>viable</em>; they do not, by
          themselves, prove it out as a whole framework. What remains untested is scale, not surface.
        </div>
      </div>
    </section>

    <!-- ───────────────────────── SUBSET ───────────────────────── -->
    <section id="subset">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <p class="text-sm font-semibold uppercase tracking-widest text-spark-400">What compiles</p>
        <h2 class="mt-3 max-w-3xl text-3xl font-bold tracking-tight md:text-4xl">
          A wide C# subset — and a compiler that refuses the rest, loudly.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-mist-300">
          Across 161 recorded decisions and 67 measured entries, the compilable surface has grown to
          cover most of everyday C# — and, since ADR 0003, the framework layer too. Anything outside
          it raises a located diagnostic and writes no file.
        </p>

        <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
          {
            subset.map((s) => (
              <div class="rounded-2xl border border-ink-800 bg-ink-850/50 p-6">
                <h3 class="flex items-center gap-2 text-base font-semibold text-mist-100">
                  <svg class="h-4 w-4 text-spark-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.1 3.1 6.8-6.8a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" />
                  </svg>
                  {s.title}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-mist-500">{s.items}</p>
              </div>
            ))
          }
        </div>

        <p class="mt-8 text-sm text-mist-500">
          Backed by <span class="font-mono text-mist-300">528</span> .NET tests and
          <span class="font-mono text-mist-300">214</span> runtime tests — every slice verified
          byte-for-byte against a Blazor-faithful answer key, then measured live in a real browser.
        </p>
      </div>
    </section>

    <!-- ───────────────────────── HONESTY ───────────────────────── -->
    <section id="honesty" class="border-t border-ink-800 bg-ink-900/40">
      <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
        <p class="text-sm font-semibold uppercase tracking-widest text-filament-500">
          What it doesn't do yet
        </p>
        <h2 class="mt-3 max-w-3xl text-3xl font-bold tracking-tight md:text-4xl">
          The verdict, stated plainly: not eliminated, not established.
        </h2>
        <p class="mt-5 max-w-2xl text-lg leading-relaxed text-mist-300">
          Filament is a thesis under test, not a shipping framework. The <em>framework</em> layer is
          no longer the caveat it was: routing, DI, inheritance, fragments, callbacks, refs,
          cascades, generics and interop are implemented and measured, and ten of the eleven cost
          <em>zero</em> runtime bytes because the compile-time model absorbed them rather than being
          extended by them. What is honest to say now is narrower, and sharper.
        </p>

        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-mist-300">
          A ten-agent probe then went back into those eleven features and wrote its own witnesses.
          It found the surface was closed at the centre and open at the edges: a form that navigates
          away on submit, a fragment forwarded twice and dropped, a parameterised route that renders
          a blank screen. Those defects are catalogued, each with the command that produced it, and
          they are being closed one measured slice at a time. The register is in the repository,
          because a limit you can read is a design constraint and a limit you discover in production
          is a bug report.
        </p>

        <div class="mt-12 grid gap-8 lg:grid-cols-2">
          <div>
            <h3 class="text-lg font-semibold text-mist-100">Not implemented</h3>
            <ul class="mt-4 flex flex-wrap gap-2.5">
              {
                nonGoals.map((n) => (
                  <li class="rounded-lg border border-ink-700 bg-ink-850/60 px-3 py-1.5 text-sm text-mist-300">
                    {n}
                  </li>
                ))
              }
            </ul>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-mist-100">Reserves</h3>
            <ul class="mt-4 space-y-3 text-sm leading-relaxed text-mist-400">
              <li class="flex gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-spark-400"></span>
                <span
                  ><span class="font-semibold text-spark-300">Banked.</span> The hand-written
                  <code class="text-mist-300">Rows</code> bundle was re-measured on the wire — 4,373 B,
                  byte-identical to the generated one.</span
                >
              </li>
              <li class="flex gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-spark-400"></span>
                <span
                  ><span class="font-semibold text-spark-300">Banked.</span> The comment-anchor node
                  debt was re-measured inside a conditional app — Filament renders 4 nodes to Blazor's
                  5. It never flips sign; it stays an advantage.</span
                >
              </li>
              <li class="flex gap-3">
                <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-filament-500"></span>
                <span
                  ><span class="font-semibold text-mist-100">Open, mitigated.</span> The generator pins
                  a frozen, out-of-support Razor toolchain — now contained to one seam, hardened to
                  fail loud, and mapped for migration. An architectural liability the thesis carries as
                  its price.</span
                >
              </li>
            </ul>
          </div>
        </div>

        <div
          class="mt-12 rounded-2xl border border-spark-500/30 bg-spark-500/5 p-6 md:p-8"
        >
          <p class="text-lg leading-relaxed text-mist-200">
            <span class="font-semibold text-spark-300">Why say all this?</span> Because the project's
            one non-negotiable rule is that it never claims more than it measured. The evidence says
            the architecture is <em>viable</em> — smaller and faster on real work. It does not yet
            say it replaces Blazor. That distinction is the whole point.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
